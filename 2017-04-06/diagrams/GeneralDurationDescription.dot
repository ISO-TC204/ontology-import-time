// Diagram for GeneralDurationDescription
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=max
		GeneralDurationDescription [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER" PORT="e">GeneralDurationDescription</TD></TR><HR/><TR><TD ALIGN="LEFT">«max 1» days: xsd:decimal</TD></TR><TR><TD ALIGN="LEFT">«max 1» hours: xsd:decimal</TD></TR><TR><TD ALIGN="LEFT">«max 1» minutes: xsd:decimal</TD></TR><TR><TD ALIGN="LEFT">«max 1» months: xsd:decimal</TD></TR><TR><TD ALIGN="LEFT">«max 1» seconds: xsd:decimal</TD></TR><TR><TD ALIGN="LEFT">«max 1» weeks: xsd:decimal</TD></TR><TR><TD ALIGN="LEFT">«max 1» years: xsd:decimal</TD></TR></TABLE>> URL="../GeneralDurationDescription" margin=0]
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		owl_Thing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">owl:Thing</TD></TR></TABLE>> margin=0]
	}
	TemporalDuration [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TemporalDuration</TD></TR></TABLE>> URL="../TemporalDuration" margin=0]
	GeneralDurationDescription -> TemporalDuration [arrowhead=onormal style=solid]
	GeneralDurationDescription -> Invis [style=invis]
	Invis -> owl_Thing [style=invis]
	GeneralDurationDescription -> owl_Thing [label=" hasTRS 
 «exactly 1»  " arrowhead=normal style=solid]
}
