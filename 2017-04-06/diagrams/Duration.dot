// Diagram for Duration
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=max
		Duration [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER" PORT="e">Duration</TD></TR><HR/><TR><TD ALIGN="LEFT">«exactly 1» numericDuration: xsd:decimal</TD></TR></TABLE>> URL="../Duration" margin=0]
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		owl_Thing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">owl:Thing</TD></TR></TABLE>> margin=0]
	}
	TemporalDuration [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TemporalDuration</TD></TR></TABLE>> URL="../TemporalDuration" margin=0]
	Duration -> TemporalDuration [arrowhead=onormal style=solid]
	Duration -> Invis [style=invis]
	Invis -> owl_Thing [style=invis]
	Duration -> owl_Thing [label=" unitType 
 «exactly 1»  " arrowhead=normal style=solid]
}
