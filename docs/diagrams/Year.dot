// Diagram for Year
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=max
		Year [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER" PORT="e">Year</TD></TR><HR/><TR><TD ALIGN="LEFT">«refined» days: xsd:decimal</TD></TR><TR><TD ALIGN="LEFT">«refined» hours: xsd:decimal</TD></TR><TR><TD ALIGN="LEFT">«refined» minutes: xsd:decimal</TD></TR><TR><TD ALIGN="LEFT">«refined» months: xsd:decimal</TD></TR><TR><TD ALIGN="LEFT">«refined» seconds: xsd:decimal</TD></TR><TR><TD ALIGN="LEFT">«refined» weeks: xsd:decimal</TD></TR><TR><TD ALIGN="LEFT">«refined» «exactly 1» years: xsd:decimal</TD></TR></TABLE>> URL="../Year" margin=0]
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
	}
	DurationDescription [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">DurationDescription</TD></TR></TABLE>> URL="../DurationDescription" margin=0]
	Year -> DurationDescription [arrowhead=onormal style=solid]
}
