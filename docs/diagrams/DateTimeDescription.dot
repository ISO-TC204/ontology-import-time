// Diagram for DateTimeDescription
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=max
		DateTimeDescription [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER" PORT="e">DateTimeDescription</TD></TR><HR/><TR><TD ALIGN="LEFT">«refined» «only» day: xsd:gDay</TD></TR><TR><TD ALIGN="LEFT">«refined» «only» month: xsd:gMonth</TD></TR><TR><TD ALIGN="LEFT">«refined» «only» year: xsd:gYear</TD></TR></TABLE>> URL="../DateTimeDescription" margin=0]
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
	}
	GeneralDateTimeDescription [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">GeneralDateTimeDescription</TD></TR></TABLE>> URL="../GeneralDateTimeDescription" margin=0]
	DateTimeDescription -> GeneralDateTimeDescription [arrowhead=onormal style=solid]
}
